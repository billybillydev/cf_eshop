{
  "name": "eshop",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:business": "bun run --filter @eshop/business build",
    "build:packages": "bun run --filter './packages/*' build",
    "build": "bun run '*' build",
    "dev": "bun run --filter './apps/*' dev",
    "dev:api": "bun --filter @eshop/api dev",
    "dev:react": "bun --filter @eshop/react dev",
    "lint": "bun run build:packages",
    "test": "bun run --filter '*' test",
    "test:react": "bun run --filter @eshop/react test",
    "test:business": "bun run --filter @eshop/business test",
    "format:apps": "prettier --write './apps/**/*.{js,jsx,ts,tsx}'",
    "format:packages": "prettier --write './packages/**/*.{js,jsx,ts,tsx}'",
    "format": "bun run format:apps && bun run format:packages",
    "prepare": "husky",
    "docker:api:up": "docker-compose up --build api",
    "docker:api:down": "docker-compose down api",
    "docker:react:up": "docker-compose up --build react",
    "docker:react:down": "docker-compose down react",
    "db:generate": "cd apps/api && bun db:generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "cd apps/api && bun db:migrate",
    "db:push": "cd apps/api && bun db:push",
    "db:seed": "cd apps/api && bun db:seed",
    "clean": "bunx rimraf --glob **/node_modules",
    "deploy:api": "fly deploy --app eshop-api --build-target api --config apps/api/fly.toml",
    "deploy:react": "fly deploy --app eshop-react --build-target react --config apps/react/fly.toml"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "bun lint & bun format"
    }
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "bun lint",
      "bun format"
    ]
  },
  "packageManager": "bun@1.0.0",
  "dependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "husky": "^9.1.1",
    "lint-staged": "^15.2.7",
    "path": "^0.12.7",
    "qs": "^6.13.0",
    "zod": "^3.25.49"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/qs": "^6.9.15",
    "@types/tailwindcss": "^3.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.2.4"
  },
  "peerDependencies": {
    "typescript": "^5.6.2"
  }
}
