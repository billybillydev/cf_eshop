{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM"],
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "types": ["bun"],
    "baseUrl": "./",
    "rootDir": "./",
    "paths": {
      "$/*": ["src/*"]
    }
  },
  "include": ["src", "worker-configuration.d.ts", "service-bindings.d.ts"],
  "exclude": ["node_modules"]
}